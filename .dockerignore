# Keep the Docker build context small and the image reproducible. The Dockerfile
# copies only: pyproject.toml, uv.lock, src/, app/, fastapi_app/, scripts/.
# Everything below is irrelevant to the build (or provided at runtime via the
# volumes declared in docker-compose.yml: ./data, ./models, ./mlruns).

# Python caches / build artifacts
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Local virtualenv (the image builds its own via uv sync)
.venv/

# Runtime data & outputs — mounted as volumes at runtime, not baked into the image
data/
models/
mlruns/
mlartifacts/
mlflow.db
mlflow.db-journal
embeddings/
best_params/

# Library temp/working dirs and logs
catboost_info/
*.log

# VCS / docs / tests not needed inside the runtime image
.git/
.gitignore
docs/
tests/
fastapi_app/tests/

# OS / editor
.DS_Store
.vscode/
.idea/
